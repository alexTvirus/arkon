# ============================================================
# Arkon — Docker Compose environment
# cp .env.docker.example .env.docker
# ============================================================

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://arkon:arkon_secret@arkon_postgres:5432/arkon

# --- Auth (JWT) ---
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-random-secret-string

# --- Default Admin Account ---
DEFAULT_ADMIN_EMAIL=admin@arkon.local
DEFAULT_ADMIN_PASSWORD=admin123

# --- MinIO ---
MINIO_ENDPOINT=arkon_minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=arkon-files
MINIO_SECURE=false
MINIO_PRESIGN_EXPIRY_HOURS=24

# --- Redis ---
REDIS_HOST=arkon_redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
WORKER_MAX_JOBS=3
WORKER_JOB_TIMEOUT=600

# --- CORS ---
# Production: set to your actual domain, e.g. https://arkon.yourcompany.com
CORS_ORIGINS=*

# --- Frontend ---
# Public URL of the API as seen by the browser
NEXT_PUBLIC_API_URL=http://localhost:5055
